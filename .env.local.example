# Resend (https://resend.com) — used to send both the admin notification
# and the applicant confirmation email.
RESEND_API_KEY=
# Verified sender address in Resend. Use onboarding@resend.dev for testing
# before a custom domain is verified.
RESEND_FROM_EMAIL=onboarding@resend.dev
# Where new-application notifications go.
ADMIN_EMAIL=yuu.chenn.zzz@gmail.com

# GitHub token (fine-grained PAT, "Contents: write" scope, limited to the
# study-abroad-studio repo) — used to persist each submission as a JSON
# file committed to that repo. Optional: submissions still get emailed
# even if this is unset, just not stored.
GITHUB_TOKEN=
GITHUB_REPO=GitHub-Zho/study-abroad-studio
